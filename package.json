{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "cypress:open": "cypress open",
        "cypress:run": "cypress run",
        "cypress:run:auth": "cypress run --spec \"cypress/e2e/1_autentikasi/**/*\"",
        "cypress:run:event": "cypress run --spec \"cypress/e2e/2_pengelolaan_event_tarif/**/*\"",
        "cypress:run:transaksi": "cypress run --spec \"cypress/e2e/3_transaksi_penitipan_pengambilan/**/*\"",
        "cypress:run:laporan": "cypress run --spec \"cypress/e2e/4_laporan/**/*\"",
        "cypress:run:user": "cypress run --spec \"cypress/e2e/5_manajemen_pengguna_profil/**/*\"",
        "cypress:run:admin": "cypress run --spec \"cypress/e2e/6_manajemen_transaksi_admin/**/*\"",
        "cypress:run:search": "cypress run --spec \"cypress/e2e/7_pencarian_global/**/*\"",
        "db:backup": "powershell -ExecutionPolicy Bypass -File ./db-backup.ps1 backup",
        "db:restore": "powershell -ExecutionPolicy Bypass -File ./db-backup.ps1 restore"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "cypress": "^15.17.0",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.7"
    }
}
